# API Configuration
NEXT_PUBLIC_API_URL=https://your-backend-url.com

# Application Configuration
NEXT_PUBLIC_APP_URL=https://your-app-url.netlify.app

# Mercado Pago Configuration
# Get these from: https://www.mercadopago.com.ar/developers/panel/credentials
# Solo necesitás la Public Key para el frontend (Wallet Brick)
# El Access Token se configura en el backend para crear preferencias
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-your-public-key-here

